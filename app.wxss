/* Dark Tech 全局主题 */
page {
  --bg-primary: #0a0a0f;
  --bg-card: #14141f;
  --text-primary: #f5f5f5;
  --text-secondary: #9e9e9e;
  --accent: #00e5ff;
  --accent-warm: #ff6d00;
  --divider: #1e1e2e;

  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-size: 14px;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
