.container {
  padding: 24rpx 32rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background-color: var(--bg-card);
  border-radius: 16rpx;
}
.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}
.search-input {
  flex: 1;
  color: var(--text-primary);
  font-size: 28rpx;
}
.clear-btn {
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 8rpx;
}

.hot-section {
  margin-top: 40rpx;
}
.hot-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}
.hot-tags {
  display: flex;
  flex-wrap: wrap;
}
.hot-tag {
  padding: 12rpx 28rpx;
  margin: 0 16rpx 16rpx 0;
  background-color: var(--bg-card);
  color: var(--text-secondary);
  font-size: 26rpx;
  border-radius: 32rpx;
}

.result-section {
  margin-top: 24rpx;
}
.result-count {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  display: block;
}
.result-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--divider);
}
.result-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background-color: #1a1a2e;
  flex-shrink: 0;
}
.result-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  background-color: #1a1a2e;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}
.result-body {
  flex: 1;
  margin-left: 24rpx;
}
.result-name {
  font-size: 30rpx;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.result-brand {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: block;
}
.result-price {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--accent);
  margin-top: 8rpx;
  display: block;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: var(--text-secondary);
}
