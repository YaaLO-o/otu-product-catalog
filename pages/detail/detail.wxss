.container {
  padding-bottom: 40rpx;
}

.detail-swiper {
  width: 100%;
  height: 600rpx;
  background-color: #14141f;
}
.detail-image {
  width: 100%;
  height: 100%;
}
.detail-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 96rpx;
}

.info-section {
  padding: 32rpx;
}
.product-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  line-height: 1.4;
}
.product-price {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--accent);
  display: block;
  margin-top: 16rpx;
}
.product-meta {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 12rpx;
}

.desc-section {
  margin: 0 32rpx 24rpx;
  padding: 24rpx;
  background-color: var(--bg-card);
  border-radius: 8rpx;
}
.desc-text {
  color: var(--text-secondary);
  font-size: 28rpx;
  line-height: 1.6;
}

.specs-section {
  margin: 0 32rpx;
}
.specs-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  display: block;
}
.specs-table {
  background-color: var(--bg-card);
  border-radius: 8rpx;
  overflow: hidden;
}
.spec-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--divider);
}
.spec-row:last-child {
  border-bottom: none;
}
.spec-key {
  color: var(--text-secondary);
  font-size: 26rpx;
}
.spec-value {
  color: var(--text-primary);
  font-size: 26rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: var(--bg-primary);
  border-top: 1rpx solid var(--divider);
}
.copy-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--accent);
  color: #0a0a0f;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}
.copy-btn::after {
  border: none;
}
.copy-icon {
  margin-right: 12rpx;
}
