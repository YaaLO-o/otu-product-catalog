.card {
  background-color: var(--bg-card);
  border-radius: 8rpx;
  overflow: hidden;
  margin: 8rpx;
}

.card-image {
  width: 100%;
  height: 340rpx;
  background-color: #1a1a2e;
}

.card-placeholder {
  width: 100%;
  height: 340rpx;
  background-color: #1a1a2e;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 64rpx;
}

.card-body {
  padding: 20rpx 16rpx;
}

.card-name {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.4;
}

.card-price {
  display: block;
  margin-top: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--accent);
}
