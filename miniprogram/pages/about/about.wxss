.container {
  padding: 64rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-section {
  text-align: center;
  margin-bottom: 48rpx;
}
.brand-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
}
.brand-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  display: block;
}

.stat-section {
  display: flex;
  justify-content: center;
  margin-bottom: 48rpx;
}
.stat-item {
  text-align: center;
  padding: 32rpx 64rpx;
  background-color: var(--bg-card);
  border-radius: 12rpx;
}
.stat-number {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--accent);
  display: block;
}
.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: block;
}

.contact-section {
  width: 100%;
  margin-bottom: 48rpx;
}
.contact-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  display: block;
}
.contact-card {
  background-color: var(--bg-card);
  padding: 28rpx 24rpx;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.contact-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}
.contact-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-top: 8rpx;
}
.contact-hint {
  font-size: 22rpx;
  color: var(--accent);
  margin-top: 8rpx;
}

.footer {
  margin-top: 40rpx;
}
.footer-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}
