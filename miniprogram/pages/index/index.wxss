.container {
  padding-bottom: 40rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  margin: 24rpx 32rpx;
  padding: 20rpx 24rpx;
  background-color: var(--bg-card);
  border-radius: 16rpx;
}
.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}
.search-placeholder {
  color: var(--text-secondary);
  font-size: 28rpx;
}

.banner-swiper {
  width: 100%;
  height: 360rpx;
}
.banner-image {
  width: 100%;
  height: 100%;
}
.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 32rpx 24rpx;
  background: linear-gradient(transparent, rgba(10, 10, 15, 0.9));
}
.banner-name {
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}
.banner-price {
  color: var(--accent);
  font-size: 28rpx;
  font-weight: 700;
  margin-top: 8rpx;
  display: block;
}

.category-grid {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 24rpx;
}
.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.category-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}
.category-name {
  color: var(--text-secondary);
  font-size: 24rpx;
}

.section {
  padding: 0 24rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}
.product-grid {
  display: flex;
  flex-wrap: wrap;
  margin: -8rpx;
}
.product-grid > product-card {
  width: 50%;
}
